<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0D47A1">

  <!-- PAGE 1: WELCOME -->
  <LinearLayout android:id="@+id/pageWelcome"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical" android:gravity="center"
      android:paddingStart="40dp" android:paddingEnd="40dp"
      android:paddingTop="60dp" android:paddingBottom="200dp">
    <TextView android:layout_width="100dp" android:layout_height="100dp"
        android:text="🏫" android:textSize="52sp" android:gravity="center"
        android:background="@drawable/logo_ring_bg" android:layout_marginBottom="24dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ElimuSaaS" android:textSize="40sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Enterprise School Management" android:textSize="14sp"
        android:textColor="#90CAF9" android:layout_marginTop="4dp" android:layout_marginBottom="20dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Kenya's most complete school management platform — students, exams, fees, attendance and more."
        android:textSize="15sp" android:textColor="#E3F2FD"
        android:gravity="center" android:lineSpacingExtra="4dp"/>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="20dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="⭐ 500+ Schools" android:textSize="13sp" android:textColor="#90CAF9" android:layout_marginEnd="24dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="👥 2M+ Students" android:textSize="13sp" android:textColor="#90CAF9"/>
    </LinearLayout>
  </LinearLayout>

  <!-- PAGE 2: FEATURES -->
  <ScrollView android:id="@+id/pageFeatures"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:visibility="gone">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp" android:paddingBottom="220dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Everything in One App" android:textSize="24sp" android:textStyle="bold"
          android:textColor="#FFFFFF" android:layout_marginTop="40dp" android:layout_marginBottom="8dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="All tools. Zero compromise."
          android:textSize="14sp" android:textColor="#90CAF9" android:layout_marginBottom="24dp"/>
      <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="2">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Exams &amp; Grades" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CBC, 8-4-4, reports" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fee Management" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M-Pesa, invoicing" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attendance" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily, reports" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SMS Parents" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bulk alerts" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📴" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Works Offline" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Syncs later" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="5dp" android:background="#1565C0" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤖" android:textSize="28sp" android:layout_marginBottom="6dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Insights" android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Smart analytics" android:textSize="11sp" android:textColor="#90CAF9"/>
        </LinearLayout>
      </GridLayout>
    </LinearLayout>
  </ScrollView>

  <!-- PAGE 3: PERMISSIONS -->
  <ScrollView android:id="@+id/pagePermissions"
      android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="32dp" android:gravity="center_horizontal"
        android:paddingBottom="220dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="🔒" android:textSize="56sp" android:gravity="center"
          android:layout_marginTop="40dp" android:layout_marginBottom="16dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="App Permissions" android:textSize="26sp" android:textStyle="bold"
          android:textColor="#FFFFFF" android:layout_marginBottom="6dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Allow these for the best experience"
          android:textSize="14sp" android:textColor="#90CAF9" android:gravity="center" android:layout_marginBottom="24dp"/>
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:background="#1565C0" android:padding="20dp" android:layout_marginBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
          <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="📷" android:textSize="22sp"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Camera" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Student photos" android:textSize="12sp" android:textColor="#90CAF9"/>
          </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
          <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="👆" android:textSize="22sp"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Biometrics" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fingerprint login" android:textSize="12sp" android:textColor="#90CAF9"/>
          </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="🔔" android:textSize="22sp"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notifications" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fee alerts, results" android:textSize="12sp" android:textColor="#90CAF9"/>
          </LinearLayout>
        </LinearLayout>
      </LinearLayout>
      <Button android:id="@+id/btnGrantPermissions"
          android:layout_width="match_parent" android:layout_height="54dp"
          android:text="Grant Permissions" android:textColor="#0D47A1"
          android:textStyle="bold" android:textSize="15sp" android:background="#FFFFFF"/>
    </LinearLayout>
  </ScrollView>

  <!-- PAGE 4: GET STARTED -->
  <LinearLayout android:id="@+id/pageGetStarted"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical" android:gravity="center"
      android:paddingStart="40dp" android:paddingEnd="40dp" android:paddingBottom="200dp"
      android:visibility="gone">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎉" android:textSize="72sp" android:gravity="center" android:layout_marginBottom="20dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="You're All Set!" android:textSize="36sp" android:textStyle="bold"
        android:textColor="#FFFFFF" android:gravity="center" android:layout_marginBottom="16dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Sign in with your school credentials. Your data is encrypted and always in sync."
        android:textSize="16sp" android:textColor="#E3F2FD" android:gravity="center" android:lineSpacingExtra="6dp"/>
  </LinearLayout>

  <!-- ════════════════════════════════════════════════
       BOTTOM BAR — drawn LAST so it's always on top
       ════════════════════════════════════════════════ -->
  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="bottom"
      android:orientation="vertical"
      android:paddingStart="24dp"
      android:paddingEnd="24dp"
      android:paddingTop="16dp"
      android:paddingBottom="48dp"
      android:background="#0D47A1">

    <!-- Dots -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:orientation="horizontal"
        android:layout_marginBottom="16dp">
      <View android:id="@+id/dot0" android:layout_width="24dp" android:layout_height="8dp"
          android:layout_marginEnd="8dp" android:background="@drawable/dot_active"/>
      <View android:id="@+id/dot1" android:layout_width="8dp" android:layout_height="8dp"
          android:layout_marginEnd="8dp" android:background="@drawable/dot_inactive"/>
      <View android:id="@+id/dot2" android:layout_width="8dp" android:layout_height="8dp"
          android:layout_marginEnd="8dp" android:background="@drawable/dot_inactive"/>
      <View android:id="@+id/dot3" android:layout_width="8dp" android:layout_height="8dp"
          android:background="@drawable/dot_inactive"/>
    </LinearLayout>

    <!-- NEXT BUTTON — white, high contrast, very visible -->
    <Button android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Next  →"
        android:textColor="#0D47A1"
        android:textSize="17sp"
        android:textStyle="bold"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"
        android:stateListAnimator="@null"/>

    <!-- Skip -->
    <TextView android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Skip"
        android:textColor="#90CAF9"
        android:textSize="15sp"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"/>
  </LinearLayout>

</FrameLayout>
