<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- Tab bar - exactly like Zeraki -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/elimu_green"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tabManageExams"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:gravity="center"
            android:text="Manage\nExams"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/elimu_green_dark"
            android:background="@drawable/tab_unselected_bg"/>

        <TextView
            android:id="@+id/tabMySubjects"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:gravity="center"
            android:text="My\nSubjects"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/tab_selected_bg"/>

        <TextView
            android:id="@+id/tabCreateExam"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:gravity="center"
            android:text="Create\nExam"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/elimu_green_dark"
            android:background="@drawable/tab_unselected_bg"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressExams"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/elimu_green"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/subjectsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>
    </ScrollView>
</LinearLayout>
