<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <TextView
            android:id="@+id/tvStudentInitials"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="EA"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/avatar_circle_bg"
            android:layout_marginEnd="14dp"/>

        <!-- Name + adm -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvStudentAdm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1266, 2 Alpha"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Grade + Marks + Position -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvStudentGrade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B+"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/elimu_green"
                android:gravity="end"/>

            <TextView
                android:id="@+id/tvStudentMarks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="71%"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"/>

            <TextView
                android:id="@+id/tvStudentPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#15/36"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
