<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F0F4FF">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:background="#0D47A1" android:padding="16dp" android:orientation="horizontal"
      android:gravity="center_vertical">
    <TextView android:id="@+id/tvSASchoolCount" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="🏫 Schools" android:textSize="18sp"
        android:textStyle="bold" android:textColor="#FFFFFF"/>
    <ProgressBar android:id="@+id/progressSASchools" android:layout_width="24dp" android:layout_height="24dp"
        android:indeterminateTint="#FFFFFF" android:visibility="gone"/>
  </LinearLayout>
  <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:id="@+id/saSchoolsContainer" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp"/>
  </ScrollView>
</LinearLayout>
