<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F4FF">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:paddingBottom="24dp">

    <!-- Profile Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="160dp"
        android:background="#0D47A1" android:orientation="vertical" android:gravity="center"
        android:padding="20dp">
      <TextView android:id="@+id/tvMoreInitials"
          android:layout_width="64dp" android:layout_height="64dp"
          android:gravity="center" android:text="E" android:textColor="#0D47A1"
          android:textSize="24sp" android:textStyle="bold"
          android:background="@drawable/avatar_circle_white_bg" android:layout_marginBottom="10dp"/>
      <TextView android:id="@+id/tvMoreName"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="User Name" android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
      <TextView android:id="@+id/tvMoreRole"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Role" android:textSize="12sp" android:textColor="#90CAF9"/>
      <TextView android:id="@+id/tvMoreSchool"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="School" android:textSize="11sp" android:textColor="#64B5F6"/>
    </LinearLayout>

    <!-- Section: Features -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SCHOOL MANAGEMENT" android:textSize="10sp" android:textStyle="bold"
        android:textColor="#6B7280" android:letterSpacing="0.1"
        android:layout_marginStart="16dp" android:layout_marginTop="20dp" android:layout_marginBottom="6dp"/>

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical">

        <LinearLayout android:id="@+id/menuAttendance" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="✅" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Attendance" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuStaff" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="👥" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Staff" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuCalendar" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="📅" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Calendar &amp; Events" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuCommunication" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="💬" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Notifications" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuReports" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="📊" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Reports &amp; Analytics" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Section: Other -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="OTHER" android:textSize="10sp" android:textStyle="bold"
        android:textColor="#6B7280" android:letterSpacing="0.1"
        android:layout_marginStart="16dp" android:layout_marginTop="20dp" android:layout_marginBottom="6dp"/>

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="#FFFFFF">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical">

        <LinearLayout android:id="@+id/menuWebPortal" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="🌐" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Open Web Portal" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuAbout" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="ℹ️" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="About ElimuSaaS" android:textSize="15sp" android:textColor="#0D1117" android:layout_marginStart="12dp"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="#9CA3AF"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F4F8" android:layout_marginStart="64dp"/>

        <LinearLayout android:id="@+id/menuLogout" android:layout_width="match_parent"
            android:layout_height="56dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
          <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="🚪" android:textSize="20sp"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Sign Out" android:textSize="15sp" android:textColor="#C62828" android:layout_marginStart="12dp"/>
        </LinearLayout>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:text="ElimuSaaS v1.0.0 · Kenya 🇰🇪"
        android:textSize="11sp" android:textColor="#9CA3AF"
        android:layout_marginTop="24dp" android:layout_marginBottom="16dp"/>
  </LinearLayout>
</ScrollView>
