<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F4FF">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:paddingBottom="24dp">

    <!-- Profile Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="160dp"
        android:background="#0D47A1" android:orientation="vertical" android:gravity="center" android:padding="20dp">
      <TextView android:id="@+id/tvMoreInitials"
          android:layout_width="64dp" android:layout_height="64dp"
          android:gravity="center" android:text="E" android:textColor="#0D47A1"
          android:textSize="24sp" android:textStyle="bold"
          android:background="@drawable/avatar_circle_white_bg" android:layout_marginBottom="10dp"/>
      <TextView android:id="@+id/tvMoreName"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="User Name" android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
      <TextView android:id="@+id/tvMoreRole"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Role" android:textSize="12sp" android:textColor="#90CAF9"/>
      <TextView android:id="@+id/tvMoreSchool"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="School" android:textSize="11sp" android:textColor="#64B5F6"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ALL FEATURES" android:textSize="10sp" android:textStyle="bold"
        android:textColor="#6B7280" android:letterSpacing="0.1"
        android:layout_marginStart="16dp" android:layout_marginTop="20dp" android:layout_marginBottom="8dp"/>

    <!-- Dynamic Grid (filled by MoreFragment.kt) -->
    <GridLayout android:id="@+id/moreGrid"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>

    <!-- Logout -->
    <Button android:id="@+id/btnMoreLogout"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="20dp" android:layout_marginBottom="8dp"
        android:background="@drawable/error_bg"
        android:text="🚪  Sign Out" android:textColor="#C62828" android:textStyle="bold" android:textSize="14sp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:text="ElimuSaaS v1.0.0 · Kenya 🇰🇪"
        android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginBottom="8dp"/>
  </LinearLayout>
</ScrollView>
