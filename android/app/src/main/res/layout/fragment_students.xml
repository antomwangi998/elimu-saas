<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F0F4FF">

    <!-- Search + count header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#0D47A1" android:padding="12dp" android:orientation="vertical">
        <EditText android:id="@+id/etStudentSearch"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:background="@drawable/search_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:hint="🔍  Search students..." android:textSize="14sp"
            android:textColor="#0D1117" android:textColorHint="#9CA3AF"
            android:inputType="text" android:singleLine="true"/>
        <TextView android:id="@+id/tvStudentCount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Loading students..." android:textSize="12sp"
            android:textColor="#90CAF9" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressStudents"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:layout_marginTop="48dp"
        android:indeterminateTint="#0D47A1" android:visibility="gone"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:id="@+id/studentsContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp"/>
    </ScrollView>
</LinearLayout>
