<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center"
    android:padding="12dp" android:layout_margin="4dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true" android:focusable="true">
  <androidx.cardview.widget.CardView
      android:layout_width="56dp" android:layout_height="56dp"
      app:cardCornerRadius="14dp" app:cardElevation="2dp"
      app:cardBackgroundColor="#E3F2FD" android:layout_marginBottom="8dp">
    <TextView android:id="@+id/tvMoreItemIcon"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:gravity="center" android:text="📊" android:textSize="24sp"/>
  </androidx.cardview.widget.CardView>
  <TextView android:id="@+id/tvMoreItemLabel"
      android:layout_width="wrap_content" android:layout_height="wrap_content"
      android:text="Feature" android:textSize="11sp" android:textStyle="bold"
      android:textColor="#374151" android:gravity="center" android:maxLines="2"/>
</LinearLayout>
